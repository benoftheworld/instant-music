# ==============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.prod and fill in your actual values
# NEVER commit .env.prod to version control!

# ============= Django Settings =============
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-super-secret-key-min-50-characters-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# CORS Settings (your frontend domain)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://benoftheworld.fr
DJANGO_ENV=production

# ============= Database =============
POSTGRES_DB=instantmusic_prod
POSTGRES_USER=instantmusic_user
POSTGRES_PASSWORD=strong-database-password-change-this
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============= Redis =============
REDIS_URL=redis://redis:6379/0

# ============= OAuth Configuration =============
# Google OAuth (Get from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# YouTube API
YOUTUBE_API_KEY=example-youtube-api-key

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://yourdomain.com

# ============= Email Configuration =============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ============= Security =============
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
# Laisser False : Nginx gère déjà la redirection HTTP→HTTPS.
# Mettre True uniquement si Django est exposé directement (sans reverse proxy).
SECURE_SSL_REDIRECT=False

# ============= Frontend URLs =============
VITE_API_URL=https://yourdomain.com/api
VITE_WS_URL=wss://yourdomain.com/ws

# ============= Monitoring (Optional) =============
# SENTRY_DSN=your-sentry-dsn-for-error-tracking

# ── ELK / Logstash ──────────────────────────────
# Activer l'envoi des logs Django vers Logstash (stack monitoring active).
# Mettre le nom du service Docker Logstash (réseau app-network).
# Laisser vide pour désactiver (default).
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000

# ── Scaling horizontal ───────────
# Nombre de workers Gunicorn (prod).
GUNICORN_WORKERS=4
# Concurrence Celery par worker (nombre de threads/processus)
CELERY_CONCURRENCY=4

# ============= Chiffrement RGPD (emails) =============
# Générer la clé avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=your-fernet-key-base64
# Chaîne secrète aléatoire longue (ex: openssl rand -hex 32)
EMAIL_HASH_KEY=your-secret-pepper-key
