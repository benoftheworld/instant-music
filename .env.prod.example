# ==============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.prod and fill in your actual values
# NEVER commit .env.prod to version control!

# ============= Django Settings =============
# Domaine de production (utilisé par nginx, monitoring, Makefile)
DOMAIN=yourdomain.com
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-super-secret-key-min-50-characters-change-this-in-production
# Clé de signature JWT (séparée du SECRET_KEY pour limiter l'impact en cas de compromission)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SIGNING_KEY=your-jwt-signing-key-change-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Path admin Django (défaut: admin/). En production, utiliser un path non prévisible.
# Générer avec : python -c "import secrets; print(f'manage-{secrets.token_hex(4)}/')"
ADMIN_URL=admin/

# CORS Settings (your frontend domain)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
DJANGO_ENV=production

# ============= Database =============
POSTGRES_DB=instantmusic_prod
POSTGRES_USER=instantmusic_user
POSTGRES_PASSWORD=strong-database-password-change-this
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============= Redis =============
# Mot de passe Redis (utilisé par docker-compose.prod.yml et par REDIS_URL)
# Générer avec : openssl rand -hex 32
REDIS_PASSWORD=strong-redis-password-change-this
REDIS_URL=redis://:strong-redis-password-change-this@redis:6379/0

# ============= OAuth Configuration =============
# Google OAuth (Get from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# YouTube API
YOUTUBE_API_KEY=example-youtube-api-key

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://yourdomain.com

# ============= Email Configuration =============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=votre-email@gmail.com

# ============= Security =============
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
# Laisser False : Nginx gère déjà la redirection HTTP→HTTPS.
# Mettre True uniquement si Django est exposé directement (sans reverse proxy).
SECURE_SSL_REDIRECT=False

# ============= Frontend URLs =============
VITE_API_URL=https://yourdomain.com/api
VITE_WS_URL=wss://yourdomain.com/ws

# Backend public base URL used to build absolute media and socket URLs
BACKEND_BASE_URL=https://yourdomain.com

# ============= Monitoring (Optional) =============
# SENTRY_DSN=your-sentry-dsn-for-error-tracking

# ── ELK / Logstash ──────────────────────────────
# Activer l'envoi des logs Django vers Logstash (stack monitoring active).
# Mettre le nom du service Docker Logstash (réseau app-network).
# Laisser vide pour désactiver (default).
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000

# Grafana admin credentials (OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
GF_ADMIN_PASSWORD=change-me-in-production
# Elasticsearch password (superuser elastic — OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
ELASTIC_PASSWORD=change-me-in-production
# Mot de passe du user built-in kibana_system (OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
KIBANA_PASSWORD=change-me-in-production
# Mot de passe du user built-in logstash_system (OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
LOGSTASH_PASSWORD=change-me-in-production

# ── Scaling horizontal ───────────
# Nombre de workers Gunicorn (prod).
GUNICORN_WORKERS=4
# Concurrence Celery par worker (nombre de threads/processus)
CELERY_CONCURRENCY=4

# ============= Chiffrement RGPD (emails) =============
# Générer la clé avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=your-fernet-key-base64
# Chaîne secrète aléatoire longue (ex: openssl rand -hex 32)
EMAIL_HASH_KEY=your-secret-pepper-key

# ── CDN / S3 Storage (optionnel) ───────────
# Si défini, les fichiers statiques et media sont stockés sur S3 avec CloudFront en CDN.
# AWS_STORAGE_BUCKET_NAME=my-instantmusic-assets
# AWS_S3_REGION_NAME=eu-west-3
# AWS_S3_CUSTOM_DOMAIN=cdn.instant-music.fr

# ── OpenTelemetry / Tracing distribué (optionnel) ───────────
# Active le tracing Django → Celery → requests. Export OTLP vers Jaeger.
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=instantmusic-backend

# ── Haute disponibilité (optionnel) ───────────
# Read replica PostgreSQL — lectures routées automatiquement via db_router.
# DB_REPLICA_HOST=db-replica
# DB_REPLICA_PORT=5432