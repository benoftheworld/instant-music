[run]
source = apps
omit =
    */migrations/*
    */__init__.py
    */admin.py
    */apps.py
    manage.py
    config/wsgi.py
    config/asgi.py
    config/settings/*
    config/otel.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    except ImportError
    TYPE_CHECKING
show_missing = true
# Lower the required coverage to a realistic target so CI doesn't fail
# when full 100% coverage is not achievable yet.
fail_under = 90

[html]
directory = htmlcov
