# Django
SECRET_KEY=replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=localhost
DJANGO_ENV=development

# Database
POSTGRES_DB=instantmusic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-secret

# YouTube API
YOUTUBE_API_KEY=example-youtube-api-key

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://127.0.0.1:3000

# ============= Email Configuration =============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@instant-music.fr

# ============= Chiffrement RGPD (emails) =============
# Générer la clé avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=your-fernet-key-base64
# Chaîne secrète aléatoire longue (ex: openssl rand -hex 32)
EMAIL_HASH_KEY=your-secret-pepper-key

# ============= Security =============
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# Path admin Django (défaut: admin/). En production, utiliser un path non prévisible.
# Générer avec : python -c "import secrets; print(f'manage-{secrets.token_hex(4)}/')"
ADMIN_URL=admin/

# Clé de signature JWT (séparée du SECRET_KEY pour limiter l'impact en cas de compromission)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SIGNING_KEY=your-jwt-signing-key

# ============= Frontend URLs =============
VITE_API_URL=https://yourdomain.com/api
VITE_WS_URL=wss://yourdomain.com/ws

# ============= Monitoring (Optional) =============
# SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Grafana admin credentials (OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
GF_ADMIN_PASSWORD=change-me-in-production

# Elasticsearch password (OBLIGATOIRE en production)
# Générer avec : openssl rand -base64 24
ELASTIC_PASSWORD=change-me-in-production

# ── Scaling horizontal ───────────
# Nombre de workers Gunicorn (prod).
GUNICORN_WORKERS=4
# Concurrence Celery par worker (nombre de threads/processus)
CELERY_CONCURRENCY=4

# ── CDN / S3 Storage (optionnel) ───────────
# Si défini, les fichiers statiques et media sont stockés sur S3 avec CloudFront en CDN.
# AWS_STORAGE_BUCKET_NAME=my-instantmusic-assets
# AWS_S3_REGION_NAME=eu-west-3
# AWS_S3_CUSTOM_DOMAIN=cdn.instant-music.fr

# ── OpenTelemetry / Tracing distribué (optionnel) ───────────
# Active le tracing Django → Celery → requests. Export OTLP vers Jaeger.
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=instantmusic-backend

# ── Haute disponibilité (optionnel) ───────────
# Read replica PostgreSQL — lectures routées automatiquement via db_router.
# DB_REPLICA_HOST=db-replica
# DB_REPLICA_PORT=5432
